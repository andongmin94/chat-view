{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "챗뷰",
  "mainBinaryName": "ChatView",
  "version": "0.2.2",
  "identifier": "com.andongmin.chatview",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": "npm.cmd run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "챗뷰",
        "width": 416,
        "height": 282,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "안동민",
    "windows": {
      "wix": {
        "language": "ko-KR"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
